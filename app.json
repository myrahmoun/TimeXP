{
  "expo": {
    "name": "TimeXP",
    "slug": "timexp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "timexp",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.timexp.app"
    },
    "android": {
      "package": "com.timexp.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
